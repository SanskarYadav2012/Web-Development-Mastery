# ===========================
# Web Development Mastery
# .gitignore
# ===========================

# ── OS generated files ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── Node.js (for split_files.js utility) ────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Logs ────────────────────────────────────────────
*.log
logs/

# ── Build / Temp output ──────────────────────────────
dist/
build/
.cache/
tmp/
temp/

# ── Environment / Secrets ────────────────────────────
.env
.env.local
.env.*.local

# ── Browser storage exports (if any) ────────────────
*.localstorage

# ── Backup files ─────────────────────────────────────
*.bak
*.backup
*.orig
